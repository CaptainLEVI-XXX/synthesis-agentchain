# ─── Deployment Keys ────────────────────────────────────
DEPLOYER_KEY=0x...           # Private key for deploying contracts

# ─── RPC URLs ───────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── For Base Sepolia deployment (override USDC) ────────
# USDC_OVERRIDE=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ─── After deploying enforcer separately ────────────────
# ENFORCER_ADDRESS=0x...

# ─── After deploying registry + tracker (for enforcer deploy) ──
# REGISTRY_ADDRESS=0x...
# TRACKER_ADDRESS=0x...

# ─── Verification ──────────────────────────────────────
BASESCAN_API_KEY=            # For contract verification on Basescan

# ─── Uniswap ───────────────────────────────────────────
UNISWAP_API_KEY=             # From Uniswap Developer Platform

# ─── Agent Keys (for setup.ts) ─────────────────────────
# PRICE_AGENT_KEY=0x...
# SWAP_AGENT_KEY=0x...
# LP_AGENT_KEY=0x...
# HOOKS_AGENT_KEY=0x...
